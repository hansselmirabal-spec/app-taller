{
  "name": "@app-taller/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "db:migrate": "typeorm migration:run -d src/database/data-source.ts",
    "db:migrate:revert": "typeorm migration:revert -d src/database/data-source.ts",
    "db:migrate:show": "typeorm migration:show -d src/database/data-source.ts",
    "db:migrate:generate": "typeorm migration:generate -d src/database/data-source.ts",
    "db:migrate:create": "typeorm migration:create",
    "db:seed": "ts-node src/database/seed.ts",
    "db:seed:mechanic": "ts-node -r tsconfig-paths/register src/database/mechanic.seed.ts",
    "db:seed:bodyshop-ws": "ts-node -r tsconfig-paths/register src/database/bodyshop-workshop.seed.ts",
    "db:seed:bodyshop": "ts-node -r tsconfig-paths/register src/database/bodyshop-catalog.seed.ts",
    "db:seed:all": "ts-node -r tsconfig-paths/register src/database/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "RUN_INTEGRATION=1 jest --testPathPatterns='\\.int\\.spec\\.ts'",
    "db:seed:demo-mechanic": "ts-node -r tsconfig-paths/register src/database/demo-mechanic.seed.ts",
    "db:seed:demo-bodyshop": "ts-node -r tsconfig-paths/register src/database/demo-bodyshop.seed.ts",
    "db:seed:demo-enrich": "ts-node -r tsconfig-paths/register src/database/demo-enrich.seed.ts",
    "db:seed:test": "ts-node -r tsconfig-paths/register src/database/seed-test-complete.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
